
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // USERS collection - doc id must be the auth UID
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // admin may read all users (server-side queries like admin panel will enforce admin)
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // E-WASTE SUBMISSIONS
    match /ewasteSubmissions/{submissionId} {
      // creation allowed by authenticated user only and must set userId to their uid
      allow create: if request.auth != null &&
                    request.resource.data.userId == request.auth.uid;

      // read own submissions
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;

      // admin full access
      allow read, update, delete: if request.auth != null &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';

      // pickup person can read assigned and update status if assigned
      allow read: if request.auth != null &&
                  get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'pickup' &&
                  resource.data.pickupPersonId == request.auth.uid;

      allow update: if request.auth != null &&
                    get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'pickup' &&
                    resource.data.pickupPersonId == request.auth.uid;
    }
  }
}
